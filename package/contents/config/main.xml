<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd" >
  <kcfgfile name=""/>

  <group name="General">
    <entry name="apiEndpoint" type="String">
      <label>API Endpoint URL</label>
      <default>http://localhost:11434/v1</default>
    </entry>
    <entry name="apiType" type="String">
      <label>API adapter id (openai, future: gemini, anthropic)</label>
      <default>openai</default>
    </entry>
    <entry name="providerName" type="String">
      <label>Provider Name</label>
      <default></default>
    </entry>
    <entry name="modelName" type="String">
      <label>Model Name</label>
      <default></default>
    </entry>
    <entry name="apiKey" type="String">
      <label>API Key</label>
      <default></default>
    </entry>
    <entry name="temperature" type="Int">
      <label>Temperature (0-100)</label>
      <default>70</default>
      <min>0</min>
      <max>100</max>
    </entry>
    <entry name="maxTokens" type="Int">
      <label>Max Tokens</label>
      <default>2048</default>
      <min>64</min>
      <max>32768</max>
    </entry>
    <entry name="reasoningEffort" type="String">
      <label>Reasoning effort: off, low, medium, high</label>
      <default>off</default>
    </entry>
    <entry name="thinkingBudget" type="Int">
      <label>Thinking token budget (Anthropic/Gemini)</label>
      <default>4096</default>
      <min>0</min>
      <max>32768</max>
    </entry>
    <entry name="showThoughts" type="Bool">
      <label>Show model thoughts (collapsible) when reasoning is enabled</label>
      <default>true</default>
    </entry>
    <entry name="usesResponsesAPI" type="Bool">
      <label>Route OpenAI-compatible requests through /v1/responses instead of /v1/chat/completions</label>
      <default>false</default>
    </entry>
    <entry name="geminiApiVariant" type="String">
      <label>Gemini API variant: legacy, interactions</label>
      <default>legacy</default>
    </entry>
    <entry name="geminiAuthMethod" type="String">
      <label>Gemini auth method: aistudio, agentplatform</label>
      <default>aistudio</default>
    </entry>
    <entry name="geminiVertexAuthType" type="String">
      <label>Agent Platform Auth Type: apikey, gcloud</label>
      <default>apikey</default>
    </entry>
    <entry name="geminiProjectId" type="String">
      <label>Google Cloud Project ID (Agent Platform only)</label>
      <default></default>
    </entry>
    <entry name="geminiLocation" type="String">
      <label>Google Cloud Location (Agent Platform only)</label>
      <default>global</default>
    </entry>
    <entry name="chatSpacing" type="Int">
      <label>Chat Spacing (px)</label>
      <default>10</default>
      <min>0</min>
      <max>24</max>
    </entry>
    <entry name="useCustomUserColor" type="Bool">
      <label>Use custom user bubble color</label>
      <default>true</default>
    </entry>
    <entry name="userColor" type="Color">
      <label>User Bubble Color</label>
      <default>#2478c1</default>
    </entry>
    <entry name="useCustomAssistantColor" type="Bool">
      <label>Use custom assistant bubble color</label>
      <default>false</default>
    </entry>
    <entry name="assistantColor" type="Color">
      <label>Assistant Bubble Color</label>
      <default>#1e2226</default>
    </entry>
    <entry name="useCustomFont" type="Bool">
      <label>Use custom UI font</label>
      <default>false</default>
    </entry>
    <entry name="customFontFamily" type="String">
      <label>Custom UI font family</label>
      <default></default>
    </entry>
    <entry name="customFontSize" type="Int">
      <label>Custom UI font size</label>
      <default>10</default>
      <min>6</min>
      <max>72</max>
    </entry>
    <entry name="useCustomCodeFont" type="Bool">
      <label>Use custom code font</label>
      <default>false</default>
    </entry>
    <entry name="customCodeFontFamily" type="String">
      <label>Custom code font family</label>
      <default>monospace</default>
    </entry>
    <entry name="customCodeFontSize" type="Int">
      <label>Custom code font size</label>
      <default>10</default>
      <min>6</min>
      <max>72</max>
    </entry>
    <entry name="useCustomThoughtsFont" type="Bool">
      <label>Use custom thoughts font</label>
      <default>false</default>
    </entry>
    <entry name="customThoughtsFontFamily" type="String">
      <label>Custom thoughts font family</label>
      <default></default>
    </entry>
    <entry name="customThoughtsFontSize" type="Int">
      <label>Custom thoughts font size</label>
      <default>8</default>
      <min>6</min>
      <max>72</max>
    </entry>
    <entry name="customSystemPrompt" type="String">
      <label>Custom System Prompt Additions</label>
      <default></default>
    </entry>
    <entry name="resizeImageAttachments" type="Bool">
      <label>Resize image attachments to max 800x600 before sending</label>
      <default>false</default>
    </entry>
    <entry name="saveChatHistory" type="Bool">
      <label>Auto-save chat history</label>
      <default>false</default>
    </entry>
    <entry name="showNotificationsMinimized" type="Bool">
      <label>Show desktop notifications for new messages/tool calls when chat is minimized</label>
      <default>true</default>
    </entry>
    <entry name="chatSaveFormat" type="String">
      <label>Chat save format</label>
      <default>jsonl</default>
    </entry>
    <entry name="autoShareCommandOutput" type="Bool">
      <label>Auto-share command output with LLM</label>
      <default>false</default>
    </entry>
    <entry name="autoRunCommands" type="Bool">
      <label>Auto-run commands from LLM (dangerous when combined with Auto-share)</label>
      <default>false</default>
    </entry>
    <entry name="showProviderInTitle" type="Bool">
      <label>Show provider and model in profile header</label>
      <default>true</default>
    </entry>
    <entry name="sysInfoOS" type="Bool">
      <label>Include OS in system prompt</label>
      <default>true</default>
    </entry>
    <entry name="sysInfoShell" type="Bool">
      <label>Include shell in system prompt</label>
      <default>true</default>
    </entry>
    <entry name="sysInfoHostname" type="Bool">
      <label>Include hostname in system prompt</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoKernel" type="Bool">
      <label>Include kernel in system prompt</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoDesktop" type="Bool">
      <label>Include desktop environment in system prompt</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoUser" type="Bool">
      <label>Include username in system prompt</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoCPU" type="Bool">
      <label>Include CPU info in system prompt</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoMemory" type="Bool">
      <label>Include memory info in system prompt</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoGPU" type="Bool">
      <label>Include GPU info in system prompt</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoDisk" type="Bool">
      <label>Include block devices in system prompt</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoNetwork" type="Bool">
      <label>Include network interfaces in system prompt</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoLocale" type="Bool">
      <label>Include locale in system prompt</label>
      <default>true</default>
    </entry>
    <entry name="xdgMigrationDone" type="Bool">
      <label>Internal: whether XDG path migration has been performed</label>
      <default>false</default>
    </entry>
    <entry name="sysInfoDateTime" type="Bool">
      <label>Include current date/time in system prompt</label>
      <default>true</default>
    </entry>
    <entry name="gatheredSysInfo" type="String">
      <label>Gathered system information (JSON, written at runtime)</label>
      <default></default>
    </entry>
    <entry name="apiKeyVersion" type="Int">
      <label>Internal: incremented when API key is saved to KDE Wallet</label>
      <default>0</default>
    </entry>
    <entry name="apiKeysFallback" type="String">
      <label>Per-slot API keys (JSON object) used when KDE Wallet is unavailable</label>
      <default></default>
    </entry>
    <entry name="apiKeyMigrated" type="Bool">
      <label>Internal: legacy single-slot API key has been migrated to per-slot</label>
      <default>false</default>
    </entry>
    <entry name="autoClearMode" type="Int">
      <label>Auto-clear mode: 0=disabled, 1=instant, 2=seconds, 3=minutes</label>
      <default>0</default>
    </entry>
    <entry name="autoClearSeconds" type="Int">
      <label>Auto-clear threshold in seconds</label>
      <default>30</default>
      <min>1</min>
      <max>3600</max>
    </entry>
    <entry name="autoClearMinutes" type="Int">
      <label>Auto-clear threshold in minutes</label>
      <default>5</default>
      <min>1</min>
      <max>1440</max>
    </entry>
    <entry name="lastClosedTimestamp" type="String">
      <label>Unix ms timestamp when panel was last closed (runtime)</label>
      <default></default>
    </entry>
    <entry name="availableModels" type="String">
      <label>Cached model lists per slot (JSON object: { "apiType:providerName": ["model-a", ...] }, written at runtime)</label>
      <default></default>
    </entry>
    <entry name="enableWebSearch" type="Bool">
      <label>Enable web search tool</label>
      <default>false</default>
    </entry>
    <entry name="enableNativeGoogleSearch" type="Bool">
      <label>Enable Native Google Search Grounding</label>
      <default>false</default>
    </entry>
    <entry name="enableNativeCodeExecution" type="Bool">
      <label>Enable Native Python Code Execution</label>
      <default>false</default>
    </entry>
    <entry name="webSearchProvider" type="String">
      <label>Selected web search provider (ollama, searxng, duckduckgo)</label>
      <default>ollama</default>
    </entry>
    <entry name="searxngUrl" type="String">
      <label>SearXNG Instance URL</label>
      <default></default>
    </entry>
    <entry name="searxngApiKey" type="String">
      <label>SearXNG API Key/Token (optional, for bypassing limiter)</label>
      <default></default>
    </entry>
    <entry name="searxngApiKeyVersion" type="Int">
      <label>Internal: incremented when SearXNG API key is saved to KDE Wallet</label>
      <default>0</default>
    </entry>
    <entry name="ollamaApiKey" type="String">
      <label>Ollama API Key (for web search) - Deprecated, kept for migration</label>
      <default></default>
    </entry>
    <entry name="ollamaSearchApiKey" type="String">
      <label>Ollama API Key specifically for Web Search</label>
      <default></default>
    </entry>
    <entry name="ollamaApiKeyVersion" type="Int">
      <label>Internal: incremented when Ollama API key is saved to KDE Wallet</label>
      <default>0</default>
    </entry>
    <entry name="ollamaSearchApiKeyVersion" type="Int">
      <label>Internal: incremented when Ollama Search API key is saved to KDE Wallet</label>
      <default>0</default>
    </entry>
    <entry name="webSearchMigrated" type="Bool">
      <label>Internal: web search enabled state has been migrated based on API key presence</label>
      <default>false</default>
    </entry>
    <entry name="openaiLastProvider" type="String">
      <label>Last selected provider preset name for the OpenAI-compatible adapter</label>
      <default></default>
    </entry>
    <entry name="openaiLastEndpoint" type="String">
      <label>Last endpoint URL used for the OpenAI-compatible adapter</label>
      <default></default>
    </entry>
    <entry name="profiles" type="String">
      <label>Saved LLM configuration profiles (JSON array)</label>
      <default></default>
    </entry>
    <entry name="activeProfileId" type="String">
      <label>ID of the currently active profile</label>
      <default></default>
    </entry>
    <entry name="profilesSchemaVersion" type="Int">
      <label>Internal schema version for profiles migration</label>
      <default>0</default>
    </entry>
    <entry name="useCommandTool" type="Bool">
      <label>Use tool calling for command execution</label>
      <default>true</default>
    </entry>
<entry name="pin" type="Bool">
      <label>Keep panel open when it loses focus</label>
      <default>false</default>
    </entry>
    <entry name="tasks" type="String">
      <label>User-defined tasks (JSON array)</label>
      <default></default>
    </entry>
    <entry name="customTools" type="String">
      <label>User-defined tools (JSON array)</label>
      <default>[{"name":"echo","description":"Echoes back the message provided.","commandTemplate":"echo {message}","requireSuperuser":false,"autoRun":false}]</default>
    </entry>
    <entry name="useSessionMultiplexer" type="Bool">
      <label>Run commands inside a persistent session</label>
      <default>false</default>
    </entry>
    <entry name="sessionMultiplexer" type="String">
      <label>Session multiplexer backend (tmux, screen)</label>
      <default>tmux</default>
    </entry>
    <entry name="sessionName" type="String">
      <label>Session name</label>
      <default>plasmallm</default>
    </entry>
    <entry name="showIconProfile" type="Bool">
      <label>Show Profile Header in header</label>
      <default>true</default>
    </entry>
    <entry name="showIconTasks" type="Bool">
      <label>Always show Tasks icon in header</label>
      <default>false</default>
    </entry>
    <entry name="showIconAuto" type="Bool">
      <label>Always show Auto Toggle icon in header</label>
      <default>false</default>
    </entry>
    <entry name="showIconHistory" type="Bool">
      <label>Show History icon in header</label>
      <default>true</default>
    </entry>
    <entry name="showIconCopy" type="Bool">
      <label>Show Copy icon in header</label>
      <default>false</default>
    </entry>
    <entry name="showIconClear" type="Bool">
      <label>Show Clear icon in header</label>
      <default>true</default>
    </entry>
    <entry name="showIconSettings" type="Bool">
      <label>Show Settings icon in header</label>
      <default>true</default>
    </entry>
    <entry name="showIconPin" type="Bool">
      <label>Show Pin icon in header</label>
      <default>true</default>
    </entry>

    <entry name="enableTools" type="Bool">
      <label>Enable tools system</label>
      <default>true</default>
    </entry>
    <entry name="enableDesktopAutomation" type="Bool">
      <label>Enable desktop automation (plasmallm-desktop-driver)</label>
      <default>false</default>
    </entry>
    <entry name="desktopAutomationToken" type="String">
      <label>Client token for desktop automation authentication</label>
      <default></default>
    </entry>
    <entry name="toolsReadFileEnabled" type="Bool">
      <label>Enable read_file tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsReadFileAutoRun" type="Bool">
      <label>Auto-run read_file tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsWriteFileEnabled" type="Bool">
      <label>Enable write_file tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsWriteFileAutoRun" type="Bool">
      <label>Auto-run write_file tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsListDirEnabled" type="Bool">
      <label>Enable list_dir tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsListDirAutoRun" type="Bool">
      <label>Auto-run list_dir tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsHttpGetEnabled" type="Bool">
      <label>Enable http_get tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsHttpGetAutoRun" type="Bool">
      <label>Auto-run http_get tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsHttpRequestEnabled" type="Bool">
      <label>Enable http_request tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsHttpRequestAutoRun" type="Bool">
      <label>Auto-run http_request tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsSearchFilesEnabled" type="Bool">
      <label>Enable search_files tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsSearchFilesAutoRun" type="Bool">
      <label>Auto-run search_files tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsGetClipboardEnabled" type="Bool">
      <label>Enable get_clipboard tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsGetClipboardAutoRun" type="Bool">
      <label>Auto-run get_clipboard tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsSetClipboardEnabled" type="Bool">
      <label>Enable set_clipboard tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsSetClipboardAutoRun" type="Bool">
      <label>Auto-run set_clipboard tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsNotifyEnabled" type="Bool">
      <label>Enable notify tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsNotifyAutoRun" type="Bool">
      <label>Auto-run notify tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsOpenUrlEnabled" type="Bool">
      <label>Enable open_url tool</label>
      <default>true</default>
    </entry>
    <entry name="toolsOpenUrlAutoRun" type="Bool">
      <label>Auto-run open_url tool</label>
      <default>false</default>
    </entry>
    <entry name="toolsPathWhitelist" type="String">
      <label>Whitelisted paths for file tools (JSON array)</label>
      <default>["$HOME"]</default>
    </entry>
    <entry name="toolsReadMaxBytes" type="Int">
      <label>Max bytes for read_file</label>
      <default>204800</default>
    </entry>
    <entry name="toolsWriteMaxBytes" type="Int">
      <label>Max bytes for write_file</label>
      <default>1048576</default>
    </entry>
    <entry name="toolsHttpMaxBytes" type="Int">
      <label>Max bytes for HTTP responses</label>
      <default>524288</default>
    </entry>
    <entry name="enableToolCallLimit" type="Bool">
      <label>Enable tool loop step limit</label>
      <default>true</default>
    </entry>
    <entry name="maxToolCallDepth" type="Int">
      <label>Max tool loop step limit</label>
      <default>30</default>
      <min>1</min>
      <max>100</max>
    </entry>
    <entry name="latexRenderMode" type="Int">
      <label>LaTeX rendering mode: -1=unset, 0=none, 1=replace, 2=advanced</label>
      <default>-1</default>
    </entry>
  </group>

</kcfg>
