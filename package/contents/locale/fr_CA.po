msgid ""
"Anthropic enables extended thinking when effort is not Off, using the token "
"budget below. Temperature is forced to max while thinking."
msgstr ""
"Anthropic active la réflexion approfondie lorsque l'effort n'est pas "
"désactivé, en utilisant le budget de jetons ci-dessous. La température est "
"forcée au maximum pendant la réflexion."

msgid "Request timed out after 30 seconds"
msgstr "La requête a expiré après 30 secondes"

msgid "Failed to parse models: %1"
msgstr "Échec de l'analyse des modèles : %1"

msgid "Failed to fetch models: HTTP %1"
msgstr "Échec de la récupération des modèles : HTTP %1"

msgid "Invalid response format"
msgstr "Format de réponse invalide"

