msgid ""
"Gemini uses the thinking token budget directly. Set to 0 to disable thinking "
"on supported models."
msgstr ""
"Gemini bruker tenke-token-budsjettet direkte. Sett til 0 for å deaktivere "
"tenking (noen modeller krever det)."

msgid "Failed to fetch models"
msgstr "Kunne ikke hente modeller..."

msgid "Authentication failed — check your API key (HTTP 400): %1"
msgstr "Autentisering feilet — sjekk API-nøkkelen din (HTTP 400): %1"

msgid "Authentication failed (HTTP %1) — check your API key: %2"
msgstr "Autentisering feilet (HTTP %1) — sjekk API-nøkkelen din: %2"

msgid "no response — check your endpoint URL"
msgstr "ingen respons — sjekk endepunkt-URL-en din..."

msgid "Request failed"
msgstr "Forespørsel feilet..."

msgid "Gemini uses the thinking level dropdown directly."
msgstr "Gemini bruker tenkenivå-nedtrekkslisten direkte."

msgid ""
"This model version does not support combining Native tools (Search/Code) "
"with custom commands. Please select a newer model (e.g., Gemini 3+) or "
"disable Native features in Settings."
msgstr ""
"Denne modellversjonen støtter ikke å kombinere innebygde verktøy (Søk/Kode) "
"med tilpassede kommandoer. Velg en nyere modell (f.eks. Gemini 3+) eller "
"deaktiver innebygde funksjoner i innstillinger."

