"Geen taken geconfigureerd. Voeg een taak toe om herbruikbare "
"promptsnelkoppelingen te maken."

#: package/contents/ui/configTasks.qml:84
msgid "Add Task"
msgstr "Taak toevoegen"

#: package/contents/ui/configTasks.qml:108
msgid "Task name"
msgstr "Taaknaam"

#: package/contents/ui/configTasks.qml:115
msgid "Prompt to send"
msgstr "Te verzenden prompt"

