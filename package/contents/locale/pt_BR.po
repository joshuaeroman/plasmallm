#: package/contents/ui/configTasks.qml:33
msgid "No tasks configured. Add a task to create reusable prompt shortcuts."
msgstr ""
"Nenhuma tarefa configurada. Adicione uma tarefa para criar atalhos de prompt "
"reutilizáveis."

#: package/contents/ui/configTasks.qml:84
msgid "Add Task"
msgstr "Adicionar tarefa"

#: package/contents/ui/configTasks.qml:108
msgid "Task name"
msgstr "Nome da tarefa"

#: package/contents/ui/configTasks.qml:115
msgid "Prompt to send"
msgstr "Prompt a enviar"

#: package/contents/ui/configTasks.qml:121
msgid "Enable auto mode (auto-run + auto-share)"
msgstr "Habilitar modo automático (auto-executar + auto-compartilhar)"

#: package/contents/ui/configTasks.qml:133
