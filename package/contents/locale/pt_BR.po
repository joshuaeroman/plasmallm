msgstr "Busca na Web"

#: package/contents/ui/configTools.qml:409
msgid "Enable web search tool"
msgstr "Habilitar ferramenta de busca na web"

#: package/contents/ui/configTools.qml:413
msgid "Allows the LLM to perform web searches."
msgstr "Permite que o LLM realize buscas na web."

