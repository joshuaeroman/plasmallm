msgstr "Ошибка аутентификации (HTTP %1) — проверьте ваш API-ключ"

msgid "Rate limited (HTTP 429) — too many requests, try again shortly"
msgstr ""
"Превышен лимит запросов (HTTP 429) — слишком много запросов, повторите позже"

msgid "Not found (HTTP 404) — check your API endpoint and model name"
msgstr "Не найдено (HTTP 404) — проверьте ваш API-эндпоинт и название модели"

msgid "API error %1"
msgstr "Ошибка API %1"

