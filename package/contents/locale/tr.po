msgstr "Sohbet geçmişini otomatik kaydet"

msgid "Saves to ~/.local/share/plasmallm/chats/"
msgstr "~/.local/share/plasmallm/chats/ konumuna kaydeder"

msgid "Notifications:"
msgstr "Bildirimler:"

msgid "Show notifications when minimized"
msgstr "Küçültüldüğünde bildirimleri göster"

msgid ""
"Show system notifications for incoming messages and tool calls when the chat "
"window is minimized or closed."
msgstr ""
"Sohbet penceresi küçültüldüğünde veya kapatıldığında gelen mesajlar ve araç "
"çağrıları için sistem bildirimleri göster."

